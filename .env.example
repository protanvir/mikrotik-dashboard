# Copy this file to .env and fill in your values
# cp .env.example .env

# MikroTik Router connection
ROUTER_IP=192.168.88.1
ROUTER_PORT=443
ROUTER_USER=admin
ROUTER_PASS=your_password_here

# Dashboard server port
PORT=3000

# Interfaces to monitor for live traffic (comma-separated, no spaces)
# Use the exact names from MikroTik: ether1,ether2,sfp-sfpplus1 etc.
MONITOR_INTERFACES=ether1,ether2,sfp-sfpplus1,sfp-sfpplus2
