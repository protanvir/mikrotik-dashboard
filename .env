# ─────────────────────────────────────────────────────────────
# MikroTik CCR2116-12G-4S+ Dashboard — Configuration
# Edit the values marked with  ← CHANGE THIS
# ─────────────────────────────────────────────────────────────

# ── Router connection ─────────────────────────────────────────
ROUTER_IP=192.168.2.1          # ← CHANGE THIS  (your router's LAN/management IP)
ROUTER_PORT=80                 # 443 = HTTPS (recommended) | 80 = plain HTTP
ROUTER_USER=aptech               # ← CHANGE THIS  (your admin username)
ROUTER_PASS=Dfs9ikbC       # ← CHANGE THIS  (your admin password)

# ── Dashboard server ──────────────────────────────────────────
PORT=3000                       # Local port the dashboard runs on (leave as-is)

# ── (Deprecated) Static interface list ─────────────────────────
# The dashboard now auto-discovers running interfaces from the router.
# MONITOR_INTERFACES is only used as a fallback if discovery fails.
# You can leave it empty or delete it.
MONITOR_INTERFACES=
